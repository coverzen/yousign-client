{
    "name": "coverzen/yousign-client",
    "description": "Client for Yousign service",
    "type": "package",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.9",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.52",
        "larastan/larastan": "^3.0",
        "nunomaduro/phpinsights": "^2.11",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0",
        "phpmd/phpmd": "@stable",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "povils/phpmnd": "^3.4",
        "psalm/plugin-laravel": "^3.0",
        "roave/security-advisories": "dev-latest",
        "squizlabs/php_codesniffer": "^3.9",
        "symfony/var-dumper": "^6.0 || ^7.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Coverzen\\Components\\YousignClient\\": "src/",
            "Coverzen\\Components\\YousignClient\\Database\\Constants\\": "database/constants",
            "Coverzen\\Components\\YousignClient\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Coverzen\\Components\\YousignClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Coverzen\\Components\\YousignClient\\YousignClientServiceProvider"
            ]
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "analyse": [
            "@php-cs-fixer",
            "@phpcs",
            "@phpinsights",
            "@phpmd",
            "@phpmnd",
            "@phpmnd-test",
            "@phpstan",
            "@psalm"
        ],
        "phpcbf": "./vendor/bin/phpcbf",
        "php-cs-fixer": "./vendor/bin/php-cs-fixer fix --dry-run --diff --ansi",
        "php-cs-fixer-fix": "./vendor/bin/php-cs-fixer fix",
        "phpcs": "./vendor/bin/phpcs",
        "phpinsights": "./vendor/bin/phpinsights -n",
        "phpmd": "./vendor/bin/phpmd --cache database,config,src,tests text phpmd.xml",
        "phpmnd": "./vendor/bin/phpmnd --extensions=all,-property,-argument,-array --strings --allow-array-mapping database src",
        "phpmnd-test": "./vendor/bin/phpmnd --extensions=all,-property,-argument,-array --allow-array-mapping tests",
        "phpstan": "./vendor/bin/phpstan analyse --memory-limit=1G",
        "psalm": "./vendor/bin/psalm",
        "test": "./vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
